# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OPTIONAL: Telegram Bot ────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then paste the token below.
# Leave blank or remove to start the server without the Telegram bot.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── STORAGE PATHS ─────────────────────────────────────────────────────────────
# Where ChromaDB persists the RAG vector index (created automatically on first run)
CHROMA_DB_PATH=./data/chroma_db

# Where scraped InfinitePay pages are cached (avoids re-scraping on restart)
SCRAPED_CACHE_PATH=./data/scraped_cache

# ChromaDB collection name (change only if you want multiple isolated indexes)
COLLECTION_NAME=infinitepay_knowledge

# ── CORS (Production) ─────────────────────────────────────────────────────────
# Space-separated list of origins allowed to call the API.
# Set this to your Railway deployment URL after the first deploy.
# Example: ALLOWED_ORIGINS=https://your-app.railway.app
# Leave blank for local development (defaults to localhost only).
# ALLOWED_ORIGINS=https://your-app.railway.app

# ── AUTH / SEED ───────────────────────────────────────────────────────────────
# Shared password for the 6 seeded demo users (admin@..., carlos.andrade@...,
# maria.souza@..., joao.silva@..., ana.lima@..., pedro.costa@...). The code
# default is intentionally weak so the startup config guard flags it when
# ENVIRONMENT=production — set a strong value on Railway before any external
# sharing. Generate one with: python -c "import secrets; print(secrets.token_urlsafe(18))"
# MOCK_USER_PASSWORD=choose-a-strong-password-before-sharing
# Set to false to skip seeding demo users on startup (e.g. production).
SEED_MOCK_USERS=true
# JWT signing secret — MUST be ≥32 random bytes in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production

# ── RUNTIME ENVIRONMENT ───────────────────────────────────────────────────────
# Set to "production" on Railway so the startup config guard can page on
# seeded/default secrets. Leave empty locally.
ENVIRONMENT=development

# ── OBSERVABILITY: LangSmith (optional) ───────────────────────────────────────
# Create a key at https://smith.langchain.com → Settings → API Keys.
# When set, every LangGraph node + ReAct tool call is traced automatically.
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT="InfinitePay Agent Swarm"
LANGSMITH_TRACING=true

# ── LOGGING ───────────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── PRODUCTION ONLY (leave unset for local dev) ───────────────────────────────
# Postgres connection. In dev we fall back to SQLite at data/app.db.
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname
#
# Telegram webhook mode (Railway/prod). Mutually exclusive with polling — set
# TELEGRAM_POLLING_ENABLED=false in prod. Secret authenticates incoming updates.
# TELEGRAM_WEBHOOK_URL=https://your-app.railway.app
# TELEGRAM_POLLING_ENABLED=false
# TELEGRAM_WEBHOOK_SECRET=generate_with_secrets.token_urlsafe_48
#
# Cloudflare Turnstile CAPTCHA (enforced after 3 failed logins).
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
#
# Email provider (Resend recommended for demos — 3k/month free).
# Without a verified domain Resend can only send to the account owner's email.
# EMAIL_PROVIDER=resend
# EMAIL_API_KEY=re_xxx
# EMAIL_FROM="InfinitePay Assistant <noreply@yourdomain.com>"
#
# Keep /docs, /redoc, /openapi.json off in prod (default already false).
# ENABLE_DOCS=false
#
# Response-cache TTL for Knowledge answers. Default 900s. Set 0 to disable.
# RESPONSE_CACHE_TTL_SECONDS=900
