# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OPTIONAL: Telegram Bot ────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram, then paste the token below.
# Leave blank or remove to start the server without the Telegram bot.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── STORAGE PATHS ─────────────────────────────────────────────────────────────
# Where ChromaDB persists the RAG vector index (created automatically on first run)
CHROMA_DB_PATH=./data/chroma_db

# Where scraped InfinitePay pages are cached (avoids re-scraping on restart)
SCRAPED_CACHE_PATH=./data/scraped_cache

# ChromaDB collection name (change only if you want multiple isolated indexes)
COLLECTION_NAME=infinitepay_knowledge

# ── CORS (Production) ─────────────────────────────────────────────────────────
# Space-separated list of origins allowed to call the API.
# Set this to your Railway deployment URL after the first deploy.
# Example: ALLOWED_ORIGINS=https://your-app.railway.app
# Leave blank for local development (defaults to localhost only).
# ALLOWED_ORIGINS=https://your-app.railway.app

# ── AUTH / SEED ───────────────────────────────────────────────────────────────
# Shared password for the 5 seeded demo users (carlos.andrade@..., maria.souza@...,
# joao.silva@..., ana.lima@..., pedro.costa@...). Rotate BEFORE any external use.
MOCK_USER_PASSWORD=Test123!
# Set to false to skip seeding demo users on startup (e.g. production).
SEED_MOCK_USERS=true
# JWT signing secret — MUST be ≥32 random bytes in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-in-production

# ── LOGGING ───────────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
